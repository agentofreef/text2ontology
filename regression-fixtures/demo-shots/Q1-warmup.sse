data: {"arguments":{"groupBy":["EmployeeID","EMPLOYEE.FirstName","EMPLOYEE.LastName"],"limit":3,"metric":"count(OrderID)","odName":"ORDER_ENT","orderBy":[{"dir":"DESC","label":"count(OrderID)"}]},"name":"compose_query","result":{"composed":true,"execution_error":"","execution_result":"[{\"EmployeeID\":4,\"FirstName\":\"Margaret\",\"LastName\":\"Peacock\",\"Total_OrderID\":1908},{\"EmployeeID\":1,\"FirstName\":\"Nancy\",\"LastName\":\"Davolio\",\"Total_OrderID\":1846},{\"EmployeeID\":3,\"FirstName\":\"Janet\",\"LastName\":\"Leverling\",\"Total_OrderID\":1846}]","execution_status":"success","filters":null,"generated_sql":"SELECT\n  dims.\"EmployeeID\",\n  dims.\"FirstName\",\n  dims.\"LastName\",\n  COALESCE(COUNT(\"ORDER_ENT\".\"OrderID\"), 0) AS \"Total_OrderID\"\nFROM (SELECT * FROM (SELECT DISTINCT \"ORDER_ENT\".\"EmployeeID\" AS \"EmployeeID\" FROM (SELECT od.\"CustomerID\", od.\"EmployeeID\", od.\"Freight\", od.\"OrderDate\", od.\"OrderID\" FROM (SELECT \n  \"OrderID\",\n  \"CustomerID\", \n  \"EmployeeID\",\n  \"OrderDate\",\n  \"Freight\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Orders\") AS od) AS \"ORDER_ENT\") d0 CROSS JOIN (SELECT DISTINCT \"EMPLOYEE\".\"FirstName\" AS \"FirstName\", \"EMPLOYEE\".\"LastName\" AS \"LastName\", \"EMPLOYEE\".\"EmployeeID\" AS \"__EMPLOYEE_EmployeeID_jk__\" FROM (SELECT od.\"Country\", od.\"EmployeeID\", od.\"FirstName\", od.\"LastName\", od.\"Title\" FROM (SELECT \n  \"EmployeeID\",\n  \"FirstName\", \n  \"LastName\",\n  \"Title\",\n  \"Country\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Employees\") AS od) AS \"EMPLOYEE\") d1) dims\nLEFT JOIN (SELECT od.\"CustomerID\", od.\"EmployeeID\", od.\"Freight\", od.\"OrderDate\", od.\"OrderID\" FROM (SELECT \n  \"OrderID\",\n  \"CustomerID\", \n  \"EmployeeID\",\n  \"OrderDate\",\n  \"Freight\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Orders\") AS od) AS \"ORDER_ENT\" ON \"ORDER_ENT\".\"EmployeeID\" = dims.\"EmployeeID\"\n  AND \"ORDER_ENT\".\"EmployeeID\" = dims.\"__EMPLOYEE_EmployeeID_jk__\"\nGROUP BY 1, 2, 3\nORDER BY \"Total_OrderID\" DESC\nLIMIT 3","groupBy":["EmployeeID","EMPLOYEE.FirstName","EMPLOYEE.LastName"],"limit":3,"metric":"count(OrderID)","odName":"ORDER_ENT","orderBy":[{"prop":"count(OrderID)","dir":"DESC"}],"total_rows":3},"type":"function_call"}

