hone\", od.\"PostalCode\", od.\"Region\" FROM (SELECT \n  \"CustomerID\",\n  \"CompanyName\", \n  \"ContactName\",\n  \"ContactTitle\",\n  \"Address\",\n  \"City\",\n  \"Region\",\n  \"PostalCode\",\n  \"Country\",\n  \"Phone\",\n  \"Fax\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Customers\") AS od) AS \"CUSTOMER\" ON (\"ORDER_ENT\".\"CustomerID\" = \"CUSTOMER\".\"CustomerID\") INNER JOIN (SELECT od.\"CategoryID\", od.\"Discontinued\", od.\"ProductID\", od.\"ProductName\", od.\"ReorderLevel\", od.\"SupplierID\", od.\"UnitPrice\", od.\"UnitsInStock\", od.\"UnitsOnOrder\" FROM (SELECT \n  \"ProductID\",\n  \"ProductName\", \n  \"CategoryID\",\n  \"SupplierID\",\n  \"UnitPrice\",\n  \"UnitsInStock\",\n  \"UnitsOnOrder\",\n  \"ReorderLevel\",\n  \"Discontinued\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Products\") AS od) AS \"PRODUCT\" ON (\"ORDER_DETAIL\".\"ProductID\" = \"PRODUCT\".\"ProductID\") WHERE ((\"PRODUCT\".\"CategoryID\" = '1') AND (\"CUSTOMER\".\"Country\" IN ('Germany', 'France', 'UK', 'Italy', 'Spain')) AND (\"ORDER_ENT\".\"OrderDate\" BETWEEN '2017-01-01' AND '2017-12-31') AND (\"ORDER_DETAIL\".\"Discount\" \u003c= 0.1)) GROUP BY \"CUSTOMER\".\"Country\" ORDER BY \"Total_Quantity\" DESC LIMIT 1000","groupBy":["CUSTOMER.Country"],"limit":0,"metric":"sum(Quantity)","odName":"ORDER_DETAIL","orderBy":[{"prop":"sum(Quantity)","dir":"DESC"}],"total_rows":5},"type":"function_call"}

