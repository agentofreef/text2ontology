data: {"arguments":{"filters":[{"op":"in","property":"CUSTOMER.Country","value":"Germany,France,UK,Italy,Spain"},{"op":"\u003c=","property":"Discount","value":"0.1"},{"op":"=","property":"PRODUCT.CategoryID","value":"1"}],"groupBy":["CUSTOMER.CompanyName"],"limit":20,"metric":"sum(Quantity)","odName":"ORDER_DETAIL","orderBy":[{"dir":"DESC","label":"sum(Quantity)"}]},"name":"compose_query","result":{"composed":true,"execution_error":"","execution_result":"[{\"CompanyName\":\"B's Beverages\",\"Total_Quantity\":32261},{\"CompanyName\":\"Folies gourmandes\",\"Total_Quantity\":30258},{\"CompanyName\":\"Spécialités du monde\",\"Total_Quantity\":28927},{\"CompanyName\":\"France restauration\",\"Total_Quantity\":28785},{\"CompanyName\":\"Morgenstern Gesundkost\",\"Total_Quantity\":28661},{\"CompanyName\":\"Bólido Comidas preparadas\",\"Total_Quantity\":27892},{\"CompanyName\":\"Consolidated Holdings\",\"Total_Quantity\":27560},{\"CompanyName\":\"Victuailles en stock\",\"Total_Quantity\":27517},{\"CompanyName\":\"Island Trading\",\"Total_Quantity\":27276},{\"CompanyName\":\"QUICK-Stop\",\"Total_Quantity\":26859},{\"CompanyName\":\"Ottilies Käseladen\",\"Total_Quantity\":26581},{\"CompanyName\":\"Godos Cocina Típica\",\"Total_Quantity\":26413},{\"CompanyName\":\"Romero y tomillo\",\"Total_Quantity\":26412},{\"CompanyName\":\"Seven Seas Imports\",\"Total_Quantity\":26360},{\"CompanyName\":\"Drachenblut Delikatessen\",\"Total_Quantity\":26321},{\"CompanyName\":\"Magazzini Alimentari Riuniti\",\"Total_Quantity\":26170},{\"CompanyName\":\"Blondesddsl père et fils\",\"Total_Quantity\":26167},{\"CompanyName\":\"Galería del gastrónomo\",\"Total_Quantity\":26052},{\"CompanyName\":\"Franchi S.p.A.\",\"Total_Quantity\":25955},{\"CompanyName\":\"Paris spécialités\",\"Total_Quantity\":25950}]","execution_status":"success","filters":[{"prop":"CUSTOMER.Country","op":"in","value":"Germany,France,UK,Italy,Spain"},{"prop":"Discount","op":"\u003c=","value":"0.1"},{"prop":"PRODUCT.CategoryID","