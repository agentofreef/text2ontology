data: {"arguments":{"filters":[{"op":"=","property":"PRODUCT.CategoryID","value":"1"},{"op":"in","property":"CUSTOMER.Country","value":"Germany,France,UK,Italy,Spain"},{"op":"between","property":"ORDER_ENT.OrderDate","value":"2017-01-01,2017-12-31"},{"op":"\u003c=","property":"Discount","value":"0.1"}],"groupBy":["CUSTOMER.CustomerID","CUSTOMER.CompanyName"],"limit":10,"metric":"sum(Quantity)","odName":"ORDER_DETAIL","orderBy":[{"dir":"DESC","label":"sum(Quantity)"}]},"name":"compose_query","result":{"composed":true,"execution_error":"","execution_result":"[{\"CompanyName\":\"La corne d'abondance\",\"CustomerID\":\"LACOR\",\"Total_Quantity\":4137},{\"CompanyName\":\"Consolidated Holdings\",\"CustomerID\":\"CONSH\",\"Total_Quantity\":3292},{\"CompanyName\":\"Du monde entier\",\"CustomerID\":\"DUMON\",\"Total_Quantity\":3177},{\"CompanyName\":\"Spécialités du monde\",\"CustomerID\":\"SPECD\",\"Total_Quantity\":3053},{\"CompanyName\":\"Romero y tomillo\",\"CustomerID\":\"ROMEY\",\"Total_Quantity\":3036},{\"CompanyName\":\"Paris spécialités\",\"CustomerID\":\"PARIS\",\"Total_Quantity\":2988},{\"CompanyName\":\"B's Beverages\",\"CustomerID\":\"BSBEV\",\"Total_Quantity\":2909},{\"CompanyName\":\"Victuailles en stock\",\"CustomerID\":\"VICTE\",\"Total_Quantity\":2909},{\"CompanyName\":\"FISSA Fabrica Inter. Salchichas S.A.\",\"CustomerID\":\"FISSA\",\"Total_Quantity\":2879},{\"CompanyName\":\"Reggiani Caseifici\",\"CustomerID\":\"REGGC\",\"Total_Quantity\":2872}]","execution_status":"success","filters":[{"prop":"PRODUCT.CategoryID","op":"=","value":"1"},{"prop":"CUSTOMER.Country","op":"in","value":"Germany,France,UK,Italy,Spain"},{"prop":"ORDER_ENT.OrderDate","op":"between","value":"2017-01-01,2017-12-31"},{"prop":"Discount","op":"\u003c=","value":"0.1"}],"generated_sql":"SELECT \"CUSTOMER\".\"CustomerID\" AS \"CustomerID\", \"CUSTOMER\".\"CompanyName\" AS \"CompanyName\", SUM(\"ORDER_DETAIL\".\"Quantity\") AS \"Total_Quantity\" FROM (SELECT od.\"Discount\", od.\"OrderID\", od.\"ProductID\", od.\"Quantity\", od.\"UnitPrice\" FROM (SELECT \n  \"OrderID\",\n  \"ProductID\", \n  \"UnitPrice\",\n  \"Quantity\",\n  \"Discount\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Order Details\") AS od) AS \"ORDER_DETAIL\" INNER JOIN (SELECT od.\"CustomerID\", od.\"EmployeeID\", od.\"Freight\", od.\"OrderDate\", od.\"OrderID\" FROM (SELECT \n  \"OrderID\",\n  \"CustomerID\", \n  \"EmployeeID\",\n  \"OrderDate\",\n  \"Freight\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Orders\") AS od) AS \"ORDER_ENT\" ON (\"ORDER_DETAIL\".\"OrderID\" = \"ORDER_ENT\".\"OrderID\") INNER JOIN (SELECT od.\"Address\", od.\"City\", od.\"CompanyName\", od.\"ContactName\", od.\"ContactTitle\", od.\"Country\", od.\"CustomerID\", od.\"Fax\", od.\"Phone\", od.\"PostalCode\", od.\"Region\" FROM (SELECT \n  \"CustomerID\",\n  \"CompanyName\", \n  \"ContactName\",\n  \"ContactTitle\",\n  \"Address\",\n  \"City\",\n  \"Region\",\n  \"PostalCode\",\n  \"Country\",\n  \"Phone\",\n  \"Fax\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Customers\") AS od) AS \"CUSTOMER\" ON (\"ORDER_ENT\".\"CustomerID\" = \"CUSTOMER\".\"CustomerID\") INNER JOIN (SELECT od.\"CategoryID\", od.\"Discontinued\", od.\"ProductID\", od.\"ProductName\", od.\"ReorderLevel\", od.\"SupplierID\", od.\"UnitPrice\", od.\"UnitsInStock\", od.\"UnitsOnOrder\" FROM (SELECT \n  \"ProductID\",\n  \"ProductName\", \n  \"CategoryID\",\n  \"SupplierID\",\n  \"UnitPrice\",\n  \"UnitsInStock\",\n  \"UnitsOnOrder\",\n  \"ReorderLevel\",\n  \"Discontinued\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Products\") AS od) AS \"PRODUCT\" ON (\"ORDER_DETAIL\".\"ProductID\" = \"PRODUCT\".\"ProductID\") WHERE ((\"PRODUCT\".\"CategoryID\" = '1') AND (\"CUSTOMER\".\"Country\" IN ('Germany', 'France', 'UK', 'Italy', 'Spain')) AND (\"ORDER_ENT\".\"OrderDate\" BETWEEN '2017-01-01' AND '2017-12-31') AND (\"ORDER_DETAIL\".\"Discount\" \u003c= 0.1)) GROUP BY \"CUSTOMER\".\"CustomerID\", \"CUSTOMER\".\"CompanyName\" ORDER BY \"Total_Quantity\" DESC LIMIT 10","groupBy":["CUSTOMER.CustomerID","CUSTOMER.CompanyName"],"limit":10,"metric":"sum(Quantity)","odName":"ORDER_DETAIL","orderBy":[{"prop":"sum(Quantity)","dir":"DESC"}],"total_rows":10},"type":"function_call"}

