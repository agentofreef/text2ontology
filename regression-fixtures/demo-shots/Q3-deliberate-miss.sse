data: {"arguments":{"intent":"EU.Beverage.Quantity.2017","params":{}},"name":"smartquery","result":{"_spec_filters":[],"_spec_groupBy":null,"_spec_metric":"","bound_spec":{"filters":[],"groupBy":null,"intent":"EU.Beverage.Quantity.2017","intentId":"b1eff56a-c9e3-467d-b6f1-f3d7bffb0700","limit":0,"metric":"","objects":["ORDER_DETAIL","PRODUCT","CUSTOMER","ORDER_ENT"],"orderBy":[]},"displayMode":"table","execution_error":"","execution_result":"[{\"Total_Quantity\":88588}]","execution_status":"success","generated_sql":"SELECT SUM(\"ORDER_DETAIL\".\"Quantity\") AS \"Total_Quantity\" FROM (SELECT od.\"Discount\", od.\"OrderID\", od.\"ProductID\", od.\"Quantity\", od.\"UnitPrice\" FROM (SELECT \n  \"OrderID\",\n  \"ProductID\", \n  \"UnitPrice\",\n  \"Quantity\",\n  \"Discount\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Order Details\") AS od) AS \"ORDER_DETAIL\" INNER JOIN (SELECT od.\"CategoryID\", od.\"Discontinued\", od.\"ProductID\", od.\"ProductName\", od.\"ReorderLevel\", od.\"SupplierID\", od.\"UnitPrice\", od.\"UnitsInStock\", od.\"UnitsOnOrder\" FROM (SELECT \n  \"ProductID\",\n  \"ProductName\", \n  \"CategoryID\",\n  \"SupplierID\",\n  \"UnitPrice\",\n  \"UnitsInStock\",\n  \"UnitsOnOrder\",\n  \"ReorderLevel\",\n  \"Discontinued\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Products\") AS od) AS \"PRODUCT\" ON (\"ORDER_DETAIL\".\"ProductID\" = \"PRODUCT\".\"ProductID\") INNER JOIN (SELECT od.\"CustomerID\", od.\"EmployeeID\", od.\"Freight\", od.\"OrderDate\", od.\"OrderID\" FROM (SELECT \n  \"OrderID\",\n  \"CustomerID\", \n  \"EmployeeID\",\n  \"OrderDate\",\n  \"Freight\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Orders\") AS od) AS \"ORDER_ENT\" ON (\"ORDER_DETAIL\".\"OrderID\" = \"ORDER_ENT\".\"OrderID\") INNER JOIN (SELECT od.\"Address\", od.\"City\", od.\"CompanyName\", od.\"ContactName\", od.\"ContactTitle\", od.\"Country\", od.\"CustomerID\", od.\"Fax\", od.\"Phone\", od.\"PostalCode\", od.\"Region\" FROM (SELECT \n  \"CustomerID\",\n  \"CompanyName\", \n  \"ContactName\",\n  \"ContactTitle\",\n  \"Address\",\n  \"City\",\n  \"Region\",\n  \"PostalCode\",\n  \"Country\",\n  \"Phone\",\n  \"Fax\"\nFROM \"proj_67f18a21b93048a4b214661fb9c54390\".\"Customers\") AS od) AS \"CUSTOMER\" ON (\"ORDER_ENT\".\"CustomerID\" = \"CUSTOMER\".\"CustomerID\") WHERE ((\"PRODUCT\".\"CategoryID\" = '1') AND (\"CUSTOMER\".\"Country\" IN ('Germany', 'France', 'UK', 'Italy', 'Spain')) AND (\"ORDER_ENT\".\"OrderDate\" BETWEEN '2017-01-01' AND '2017-12-31') AND (\"ORDER_DETAIL\".\"Discount\" \u003c= 0.1)) LIMIT 1000","involved":{"kind":"smartquery","odNames":["ORDER_DETAIL","PRODUCT","CUSTOMER","ORDER_ENT"],"propertyKeys":[{"odName":"ORDER_DETAIL","propName":"Discount"},{"odName":"ORDER_DETAIL","propName":"OrderID"},{"odName":"ORDER_DETAIL","propName":"ProductID"},{"odName":"ORDER_DETAIL","propName":"Quantity"},{"odName":"ORDER_DETAIL","propName":"UnitPrice"},{"odName":"PRODUCT","propName":"CategoryID"},{"odName":"PRODUCT","propName":"Discontinued"},{"odName":"PRODUCT","propName":"ProductID"},{"odName":"PRODUCT","propName":"ProductName"},{"odName":"PRODUCT","propName":"ReorderLevel"},{"odName":"PRODUCT","propName":"SupplierID"},{"odName":"PRODUCT","propName":"UnitPrice"},{"odName":"PRODUCT","propName":"UnitsInStock"},{"odName":"PRODUCT","propName":"UnitsOnOrder"},{"odName":"CUSTOMER","propName":"Address"},{"odName":"CUSTOMER","propName":"City"},{"odName":"CUSTOMER","propName":"CompanyName"},{"odName":"CUSTOMER","propName":"ContactName"},{"odName":"CUSTOMER","propName":"ContactTitle"},{"odName":"CUSTOMER","propName":"Country"},{"odName":"CUSTOMER","propName":"CustomerID"},{"odName":"CUSTOMER","propName":"Fax"},{"odName":"CUSTOMER","propName":"Phone"},{"odName":"CUSTOMER","propName":"PostalCode"},{"odName":"CUSTOMER","propName":"Region"},{"odName":"ORDER_ENT","propName":"CustomerID"},{"odName":"ORDER_ENT","propName":"EmployeeID"},{"odName":"ORDER_ENT","propName":"Freight"},{"odName":"ORDER_ENT","propName":"OrderDate"},{"odName":"ORDER_ENT","propName":"OrderID"}]},"matched_intent":"EU.Beverage.Quantity.2017","matched_intent_id":"b1eff56a-c9e3-467d-b6f1-f3d7bffb0700","ontology_sql":"SELECT SUM(\"ORDER_DETAIL\".\"Quantity\") AS \"Total_Quantity\" FROM \"ORDER_DETAIL\" INNER JOIN \"PRODUCT\" ON (\"ORDER_DETAIL\".\"ProductID\" = \"PRODUCT\".\"ProductID\") INNER JOIN \"ORDER_ENT\" ON (\"ORDER_DETAIL\".\"OrderID\" = \"ORDER_ENT\".\"OrderID\") INNER JOIN \"CUSTOMER\" ON (\"ORDER_ENT\".\"CustomerID\" = \"CUSTOMER\".\"CustomerID\") WHERE ((\"PRODUCT\".\"CategoryID\" = '1') AND (\"CUSTOMER\".\"Country\" IN ('Germany', 'France', 'UK', 'Italy', 'Spain')) AND (\"ORDER_ENT\".\"OrderDate\" BETWEEN '2017-01-01' AND '2017-12-31') AND (\"ORDER_DETAIL\".\"Discount\" \u003c= 0.1)) LIMIT 1000","preview_warning":"","summary":"","tokenMappings":[],"total_rows":1},"type":"function_call"}

