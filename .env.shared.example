# .env.shared.example
#
# Copy this file to `.env.shared` and fill in passwords / API keys before
# running `docker compose up`. `.env.shared` is in .gitignore — never commit it.
#
# All defaults below assume the bundled Postgres in docker-compose.yml
# (no external DB needed). If you want to use an external Postgres, change
# DATABASE_URL_CONTAINER to point to it.

# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────

# Password for the bundled Postgres container.
# Pick a strong random value (e.g. `openssl rand -base64 24`) on first setup.
POSTGRES_PASSWORD=t2o_change_me_to_strong_random

# Host-side connection (for running tools like psql from your laptop).
# `localhost:5438` matches the host port mapping in docker-compose.yml.
DATABASE_URL=postgres://lakehouse2ontology-enterprise:t2o_change_me_to_strong_random@localhost:5438/lakehouse2ontology-enterprise?sslmode=disable

# Container-side connection (used by all 7 services).
# Uses compose internal DNS: `postgres:5432`.
DATABASE_URL_CONTAINER=postgres://lakehouse2ontology-enterprise:t2o_change_me_to_strong_random@postgres:5432/lakehouse2ontology-enterprise?sslmode=disable

# IMPORTANT: keep POSTGRES_PASSWORD and the passwords inside DATABASE_URL /
# DATABASE_URL_CONTAINER in sync. If you change one, change all three.

# ─────────────────────────────────────────────────────────────
# INTERNAL SERVICE AUTH
# ─────────────────────────────────────────────────────────────

# Service-to-service token (required for /internal/* endpoints).
# Generate strong: `openssl rand -hex 32`. Empty = startup fails.
INTERNAL_TOKEN=

# ─────────────────────────────────────────────────────────────
# USER AUTH
# ─────────────────────────────────────────────────────────────

# REQUIRED. HMAC secret that signs every login bearer token. backend-api
# refuses to start if this is empty. Rotating invalidates all live
# sessions. Generate strong: `openssl rand -hex 32`
AUTH_TOKEN_SECRET=

# REQUIRED on first boot. The seed admin row in schema.sql ships with a
# BOOTSTRAP_REQUIRED sentinel in place of a real password hash; backend-api
# hashes ADMIN_PASSWORD and installs it the first time it sees a sentinel.
# After bootstrap completes you can clear this — the hash is in the DB.
#
# DEFAULT is "admin" so `docker compose up` lets you log in immediately
# with admin/admin. CHANGE THIS BEFORE EXPOSING THE INSTANCE TO ANYTHING
# BEYOND LOCALHOST — the startup log will warn loudly while the default
# is in place.
ADMIN_PASSWORD=admin

# REQUIRED. Browser origins allowed to call any /api/* endpoint. CORS is
# fail-closed: an empty value blocks every cross-origin request. Add your
# frontend host(s), comma-separated. For the bundled stack, the nginx
# port is 18080.
CORS_ALLOW_ORIGINS=http://localhost:18080,http://localhost:10020

# LLM API keys are NOT configured here. After the system starts, sign in and
# go to /settings/llm-config to add chat / embedding models (vendor, base URL,
# API key, model name). The keys live in the DB and are loaded per-role at
# runtime — no env restart needed.
