# .env.example — copy to `.env` and edit for production.
#
#   cp .env.example .env
#
# docker compose AUTO-READS `.env` in this directory for ${VAR} interpolation.
# Every variable below already has a safe DEV default baked into
# docker-compose.yml, so `docker compose up -d` works with NO .env at all.
# Set values here only to OVERRIDE the defaults (required before exposing the
# instance beyond localhost). `.env` is gitignored — never commit real secrets.

# ─────────────────────────────────────────────────────────────
# PRODUCTION HARDENING — flip this on for any real deployment.
# When true, the Go services FAIL-CLOSED (refuse to start) if any secret below
# is empty or left at a `*_change_me` / `admin` placeholder. Default: false.
# ─────────────────────────────────────────────────────────────
REQUIRE_STRONG_SECRETS=true

# ─────────────────────────────────────────────────────────────
# SECRETS — generate strong values: `openssl rand -hex 32`
# Use hex/alphanumeric for POSTGRES_PASSWORD to avoid URL-escaping in the DSN.
# ─────────────────────────────────────────────────────────────
# Superuser password for the bundled Postgres. All per-service least-privilege
# roles (backend_api_user, …) are created with THIS password by the db-migrate
# runner, and every service DSN is built from it. Change it = change all.
POSTGRES_PASSWORD=change_me_openssl_rand_hex_24

# HMAC key that signs user session tokens. >= 32 chars. Rotating logs everyone out.
AUTH_TOKEN_SECRET=change_me_openssl_rand_hex_32

# Service-to-service auth token for /internal/* + healthz?check=db.
INTERNAL_TOKEN=change_me_openssl_rand_hex_24

# Initial admin web-login password (user: admin). Hashed into the DB on first boot.
ADMIN_PASSWORD=change_me_strong_admin_password

# Grafana admin password (user: admin) for http://localhost:3000.
GRAFANA_ADMIN_PASSWORD=change_me_strong_grafana_password

# ─────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────
# Browser origins allowed to call /api/*. CORS is fail-closed (empty blocks all).
# Default targets the gateway; add your real public origin(s), comma-separated.
CORS_ALLOW_ORIGINS=http://localhost:28080

# Trace sampling ratio for the otel pipeline (0.0–1.0). 0.25 bounds storage; 1.0 = all.
OTEL_TRACES_SAMPLER_ARG=0.25

# Which prebuilt image tag to pull. Default `latest` = the released build from the
# default branch (main). Maintainers can pin a branch/sha published by CI, e.g.
# IMAGE_TAG=product-ready or IMAGE_TAG=sha-<sha>, then `docker compose up -d`.
IMAGE_TAG=latest

# NOTE: LLM API keys are NOT set here. After the stack is up, sign in and add
# chat / embedding models at /settings/llm-config (vendor + base URL + key +
# model). They live in the DB and load per-role at runtime — no restart needed.
